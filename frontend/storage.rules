rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Public read only for website assets; writes reserved for admins
    match /{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
